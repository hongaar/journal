{
  "name": "@curolia/web",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "plugins:sync": "node scripts/generate-plugin-registry.mjs",
    "codegen": "npm run plugins:sync",
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "typecheck": "tsc -b",
    "test": "vitest run",
    "vercel:pull:production": "vercel pull --yes --environment=production ${VERCEL_TOKEN:+--token=$VERCEL_TOKEN}",
    "vercel:build:production": "vercel build --prod ${VERCEL_TOKEN:+--token=$VERCEL_TOKEN}",
    "vercel:deploy:production": "vercel deploy --prebuilt --prod ${VERCEL_TOKEN:+--token=$VERCEL_TOKEN}"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.1",
    "@capacitor/core": "^8.3.1",
    "@capacitor/device": "^8.0.2",
    "@capacitor/push-notifications": "^8.0.3",
    "@curolia/plugin-contract": "file:../../packages/plugin-contract",
    "@curolia/plugin-google-photos": "file:../../packages/plugins/google-photos",
    "@curolia/plugin-ical": "file:../../packages/plugins/ical",
    "@curolia/plugin-lastfm": "file:../../packages/plugins/lastfm",
    "@curolia/plugin-spotify": "file:../../packages/plugins/spotify",
    "@curolia/ui": "file:../../packages/ui",
    "@floating-ui/dom": "^1.7.6",
    "@fontsource-variable/geist": "^5.2.8",
    "@supabase/supabase-js": "^2.49.8",
    "@tanstack/react-query": "^5.76.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "frimousse": "^0.3.0",
    "lucide-react": "^0.507.0",
    "maplibre-gl": "^5.5.0",
    "next-themes": "^0.4.6",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-router-dom": "^7.6.0",
    "shadcn": "^4.6.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.1.5",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.2.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "jsdom": "^26.1.0",
    "tailwindcss": "^4.1.5",
    "tw-animate-css": "^1.4.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.2",
    "vercel": "^48.12.0",
    "vite": "^8.0.10",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^3.1.2"
  }
}
