# --- Local Supabase (`npm run db:start` from repo root) -----------------
# Run `npm run db:status -w @curolia/supabase` and paste the "API URL" and "anon key" lines here.
VITE_SUPABASE_URL=http://127.0.0.1:54321
VITE_SUPABASE_PUBLISHABLE_KEY=paste-anon-key-from-db-status

# --- Hosted Supabase (optional) -----------------------------------------
# VITE_SUPABASE_URL=https://your-project.supabase.co
# VITE_SUPABASE_PUBLISHABLE_KEY=your-publishable-key

# Plugin OAuth (Google, Spotify, …) uses Supabase Edge secrets — not Vite.
# See packages/supabase/supabase/functions/.env.example and each plugin README under packages/plugins/*/
