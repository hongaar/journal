{
  "name": "curolia",
  "private": true,
  "packageManager": "npm@10.9.2",
  "workspaces": [
    "apps/*",
    "packages/*",
    "packages/plugins/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "db:start": "supabase start",
    "db:stop": "supabase stop",
    "db:status": "supabase status",
    "db:reset": "supabase db reset",
    "db:migrate": "supabase migration up",
    "db:types": "supabase gen types typescript --local > apps/web/src/lib/database.types.ts",
    "functions:sync": "node scripts/sync-plugin-supabase.mjs",
    "storybook": "npm run storybook -w @curolia/ui",
    "build-storybook": "npm run build-storybook -w @curolia/ui",
    "functions:start": "supabase functions serve",
    "functions:stop": "pkill -f 'supabase functions serve' || true",
    "mobile:sync": "npm run -w web build && npx cap sync",
    "mobile:ios": "npx cap open ios",
    "mobile:android": "npx cap open android"
  },
  "devDependencies": {
    "prettier": "^3.8.3",
    "supabase": "^2.98.0",
    "turbo": "^2.5.4"
  },
  "engines": {
    "node": ">=20"
  }
}
