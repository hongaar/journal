# Copy to `.env` in this directory (never commit `.env`).
# Loaded automatically by `supabase functions serve` / `npm run functions:start -w @curolia/supabase`.
#
# Push notifications (push-dispatch)
PUSH_DISPATCH_SECRET=
FCM_SERVER_KEY=

# Plugin OAuth (plugin-oauth) — shared by Google Photos, Spotify, etc.
# Generate key: openssl rand -base64 32
# Must be identical for every function that reads tokens; changing it breaks decryption until users unlink + re-link.
PLUGIN_OAUTH_ENCRYPTION_KEY=

# Google OAuth (Google Photos plugin; plugin-oauth + google-photos Edge functions)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Spotify OAuth (Spotify plugin; plugin-oauth + spotify Edge function)
# SPOTIFY_CLIENT_SECRET is optional — set if your Spotify app uses a client secret on token exchange.
SPOTIFY_CLIENT_ID=
# SPOTIFY_CLIENT_SECRET=

PUBLIC_APP_ORIGIN=http://127.0.0.1:5173
# Optional: override OAuth redirect_uri if defaults are wrong (tunnel, non-default API port).
# Local default is rewritten from internal http://kong:8000 → http://127.0.0.1:54321 when hostname is kong.
# PLUGIN_OAUTH_CALLBACK_URL=http://127.0.0.1:54321/functions/v1/plugin-oauth?action=callback
